# Canonical site URL — used for metadata, sitemap, canonical links and JSON-LD.
# Defaults to the live Vercel URL; set once a custom domain is connected.
NEXT_PUBLIC_SITE_URL=https://seaattitudes.vercel.app

# --- Lead delivery (configure ONE — every form emails Mary automatically) ------
# Option A — Web3Forms (https://web3forms.com): FREE, no account/dashboard.
# Enter Mary's email on their site to get an access key, then paste it here.
WEB3FORMS_ACCESS_KEY=

# Option B — Resend email (https://resend.com): free tier, needs an API key.
RESEND_API_KEY=
LEAD_TO=seaattitudesbymarylee@gmail.com
LEAD_FROM=Sea Attitudes <onboarding@resend.dev>

# Option C — generic webhook (Zapier / Make / a CRM). Receives JSON lead payloads.
LEAD_WEBHOOK_URL=

# --- Optional: studio photo batch generator (scripts/generate-studio-photos.mjs) ---
OPENAI_API_KEY=
